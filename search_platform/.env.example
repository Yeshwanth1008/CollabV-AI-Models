# Copy to .env (repo root) and fill in. Never commit the real .env — see
# .gitignore.

# Required: Claude API key for LLM-generated match explanations
# (search_platform/explain.py). Falls back to deterministic template
# explanations if unset — never a hard failure.
ANTHROPIC_API_KEY=

# Required: Postgres connection for the profile store (structured data +
# fallback vector storage — see search_platform/vector_store.py).
DATABASE_URL=postgresql://collabv:collabv_dev_pw@127.0.0.1:5432/collabv_search

# Optional. Set only if this service's repo is checked out separately from
# CollabV's own repo (local development). Deployed inside CollabV's repo,
# alongside collabv/, the default (repo root) is already correct — leave
# unset. See search_platform/collabv_connector.py.
# COLLABV_ROOT=

# Optional overrides — sane defaults are baked into search_platform/config.py.
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# LLM_MODEL=claude-haiku-4-5-20251001
# VECTOR_BACKEND=numpy   # or "pgvector" once INSTALL_PGVECTOR.md's steps are done

# sentence-transformers only needs the PyTorch backend. Without this,
# `transformers` may auto-detect a broken TensorFlow install and eagerly
# import its TF integration, which can fail and silently degrade embeddings.
USE_TF=0
TRANSFORMERS_NO_TF=1
