# ANTHROPIC_API_KEY: optional. Without it, AI features (explanations, resume
# parsing, skill-gap analysis, etc.) fall back to rule-based logic instead of
# calling Claude - the app runs fine either way.
ANTHROPIC_API_KEY=your_anthropic_key_here
PORT=8000

# Live-data-only: the professor directory starts empty and is populated
# exclusively by POST /professor/profile - never point this at a static
# seed file. Companies are similarly live-only (no COMPANIES_FILE env var
# exists anymore; ProfessorMatchEngine always starts with zero seed
# companies and reads live registrations from the DB).
PROFESSORS_FILE=professors_live.json

DB_FILE=collabv_data.db
DEBUG=false
ENABLE_EMBEDDINGS=true
ENABLE_LLM_EXPLAIN=true

# Auth (see .env.production.example for the full production auth/CORS setup).
# Leave AUTH_REQUIRED unset/false for local dev to skip needing a JWT_SECRET.
AUTH_REQUIRED=false
JWT_SECRET=dev-only-change-me

# Comma-separated allowed origins for the external CollabV website that will
# consume this API. Leave unset in dev - localhost/127.0.0.1 on any port is
# allowed automatically.
ALLOWED_ORIGINS=
