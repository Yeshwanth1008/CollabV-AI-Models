logs/

# ─── Local-only artifacts (not meant for version control) ────────────────
# User-uploaded resumes (PII) - never commit real user data.
uploads/
# Local safety backups taken before the live-data-only migration / wipe.
backups/
archive/legacy_data_backups/
# Retired static seed datasets, kept on local disk as archive per project
# decision but too large/irrelevant to track in git (3MB+ each, superseded
# by the live-data-only architecture - see API.md).
iitm_professors_nlp.json
iitm_professors_with_patents.json
iitm_patents.json
100_Companies_Collaboration_Schema.xlsx
collabv/data/problem_statements.json
# Claude Code local tool settings (machine-specific, not project source).
.claude/

# ─── retrieval/ + search_platform/ generated artifacts ──────────────────
# (*.pkl, *.db, .env already covered above)
retrieval/name_variants.json
retrieval/profile_cache.db
retrieval/data/*.json
