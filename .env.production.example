# ─── CollabV AI - production environment template ─────────────────────────
# Copy to .env.production and fill in values. Required vars marked [REQUIRED].

# ─── Server ────────────────────────────────────────────────────────────────
PORT=8000
DEBUG=false                         # never set true in prod (leaks stack traces)
# LOG_LEVEL, ENVIRONMENT: reserved for future structured-logging/env-tagging
# work - not read by any code yet, safe to leave unset.

# ─── Data ──────────────────────────────────────────────────────────────────
# Live-data-only: this must stay pointed at the empty base directory -
# professors are populated exclusively by POST /professor/profile against
# the live DB, never from a static seed file. Do not change this to one of
# the archived seed files (archive/legacy_data_backups/, archive/seed_scripts/).
PROFESSORS_FILE=professors_live.json
DB_FILE=collabv_data.db

# The active DB access path (collabv/database.py + the *_db.py modules) is
# SQLite-only today - DB_FILE above is what's actually used. collabv/db_postgres.py
# and alembic/ exist for a future Postgres migration but aren't wired into the
# live request path yet, so the vars below currently have no effect; kept here
# so the shape is documented ahead of that migration.
# DATABASE_URL=postgresql://user:pw@host:5432/collabv
# DATABASE_HOST=
# DATABASE_PORT=5432
# DATABASE_NAME=collabv
# DATABASE_USER=collabv
# DATABASE_PASSWORD=

# ─── Feature toggles ───────────────────────────────────────────────────────
ENABLE_EMBEDDINGS=true              # uses sentence-transformers (needs ~80MB model)
ENABLE_LLM_EXPLAIN=true             # uses Claude API for explanations

# ─── Anthropic ────────────────────────────────────────────────────────────
# [REQUIRED for LLM features] Without this, falls back to rule-based explanations
ANTHROPIC_API_KEY=

# ─── Auth ──────────────────────────────────────────────────────────────────
# [REQUIRED] Random 64+ byte string. Generate with: python -c "import secrets;print(secrets.token_urlsafe(64))"
JWT_SECRET=
AUTH_REQUIRED=true                  # require API key or JWT on protected endpoints

# ─── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Required in production.
ALLOWED_ORIGINS=https://app.yourcompany.com,https://www.yourcompany.com

# ─── Rate limiting (per IP, per minute) ───────────────────────────────────
RATE_LIMIT_MATCH_PER_MIN=20
RATE_LIMIT_MATCH_BURST=10
RATE_LIMIT_CONTRACT_PER_MIN=10
RATE_LIMIT_CONTRACT_BURST=5

# ─── Monitoring, Redis, patent-scraper API (reserved) ─────────────────────
# None of the vars below are read by any code yet - they're placeholders for
# future work (Sentry error tracking, a Redis-backed rate limiter instead of
# the current in-memory one, and the retired patent-scraper's external API).
# Leave unset; do not treat their presence here as evidence they're wired up.
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# REDIS_URL=
# COLLABV_IITM_PATENT_API=

# ─── This repo's own frontend/ (Next.js) - unrelated to the separate ──────
# ─── production CollabV website that will consume this API ───────────────
NEXT_PUBLIC_API_BASE=https://api.yourcompany.com
